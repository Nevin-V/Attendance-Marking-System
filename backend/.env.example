# Example environment variables — copy this to .env in production
# NEVER commit the real .env file to git!

# Generate a new secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=False

# Your Render.com domain, e.g. scan-mark-api.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1,scan-mark-api.onrender.com

# PostgreSQL URL from Render Dashboard (External Database URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://scan-mark.vercel.app
